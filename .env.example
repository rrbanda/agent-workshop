# NovaCrest Agent Workshop - Environment Configuration
# Copy this file to .env and update with your values

# =============================================================================
# Llama Stack Server
# =============================================================================
LLAMA_STACK_BASE_URL=http://localhost:8321
LLAMA_STACK_API_KEY=fake
INFERENCE_MODEL=ollama/llama3.2:3b
# INFERENCE_MODEL=vllm/qwen3-14b

# =============================================================================
# NovaCrest Backend APIs
# =============================================================================
CUSTOMER_API_BASE_URL=http://localhost:8081
FINANCE_API_BASE_URL=http://localhost:8082

# =============================================================================
# MCP Servers
# =============================================================================
CUSTOMER_MCP_SERVER_URL=http://localhost:9001/mcp
FINANCE_MCP_SERVER_URL=http://localhost:9002/mcp
PORT_FOR_CUSTOMER_MCP=9001
HOST_FOR_CUSTOMER_MCP=0.0.0.0
PORT_FOR_FINANCE_MCP=9002
HOST_FOR_FINANCE_MCP=0.0.0.0

# =============================================================================
# Mortgage Use Case (Capstone)
# =============================================================================
MORTGAGE_API_BASE_URL=http://localhost:8083
MORTGAGE_MCP_SERVER_URL=http://localhost:9003/mcp
PORT_FOR_MORTGAGE_MCP=9003
HOST_FOR_MORTGAGE_MCP=0.0.0.0

# =============================================================================
# LangGraph FastAPI Agent (Module 06 - Optional)
# =============================================================================
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
API_KEY=fake
CHAT_UI_PORT=3001
FASTAPI_URL=http://localhost:8000

# =============================================================================
# RAG (Module 08)
# =============================================================================
EMBEDDING_MODEL=granite-embedding-125m
EMBEDDING_DIMENSION=768

# =============================================================================
# Safety Shields (Module 09)
# =============================================================================
SHIELD_PROVIDER=llama-guard
SHIELD_MODEL=vllm/Llama-Guard-3-1B
SHIELD_ID=content_safety

# =============================================================================
# Evaluations (Module 10)
# =============================================================================
JUDGE_MODEL=vllm/llama-scout-17b
CANDIDATE_MODEL=vllm/qwen3-14b
LLAMA_STACK_BENCHMARK_PROVIDER_ID=localfs

# =============================================================================
# Observability - Langfuse (Module 11)
# =============================================================================
LANGFUSE_SECRET_KEY=your-secret-key
LANGFUSE_PUBLIC_KEY=your-public-key
LANGFUSE_HOST=http://localhost:3000

# =============================================================================
# Composite Agents (Module 07)
# =============================================================================
CUSTOMER_AGENT_PORT=8001
FINANCE_AGENT_PORT=8002
CUSTOMER_AGENT_URL=http://localhost:8001/mcp
FINANCE_AGENT_URL=http://localhost:8002/mcp
MCP_CUSTOMER_SERVER_URL=http://localhost:9001/mcp
MCP_FINANCE_SERVER_URL=http://localhost:9002/mcp

# =============================================================================
# Optional: Web Search (helpers/web-search)
# =============================================================================
# TAVILY_SEARCH_API_KEY=tvly-...  # Get from https://tavily.com

# =============================================================================
# Optional: Low-Code / Langflow (Module 12)
# =============================================================================
# LANGFLOW_URL=https://your-langflow-instance
# LANGFLOW_API_KEY=your-api-key
# LANGFLOW_FLOW_ID=your-flow-id
